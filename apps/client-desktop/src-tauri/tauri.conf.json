{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bsv-poker",
  "version": "0.1.0",
  "identifier": "org.rcjbr.bsvpoker",
  "build": {
    "frontendDist": "../../client-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @bsv-poker/client-web dev",
    "beforeBuildCommand": "pnpm --filter @bsv-poker/client-web build"
  },
  "app": {
    "windows": [
      {
        "title": "bsv-poker (REGTEST)",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8091 http://127.0.0.1:8092 http://127.0.0.1:18332"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"]
  }
}
